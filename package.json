{
  "name": "bie-daalt-13",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --host 127.0.0.1 partB/frontend",
    "dev:frontend:docker": "vite --host 0.0.0.0 partB/frontend",
    "dev:backend": "node --watch partB/backend/src/server.js",
    "docker:dev": "docker compose up --build",
    "docker:studio": "docker compose exec app npx prisma studio --hostname 0.0.0.0",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "test": "node --test \"partB/tests/**/*.test.js\"",
    "build": "vite build partB/frontend --outDir ../../dist/frontend",
    "lint": "eslint partB --ext .js,.jsx"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "@prisma/client": "^6.18.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "postcss": "^8.5.0",
    "prisma": "^6.18.0",
    "tailwindcss": "^3.4.17"
  }
}
